# ============================================================
# SISTEM INFORMASI AKADEMIK - Environment Configuration
# Copy file ini menjadi .env dan sesuaikan nilainya
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# Database MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=siakad_db

# JWT Configuration
JWT_SECRET=siakad-secret-key-change-this-in-production-2025
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=dev
